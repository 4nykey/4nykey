inherit cargo
if [[ -z ${PV%%*9999} ]]; then
	inherit git-r3
	EGIT_REPO_URI="https://github.com/googlefonts/${PN}.git"
else
	MY_PV="12f1fd1"
	[[ -n ${PV%%*_p*} ]] && MY_PV="${PN}-v${PV}"
	SRC_URI="
		mirror://githubcl/googlefonts/${PN}/tar.gz/${MY_PV} -> ${P}.tar.gz
		${CARGO_CRATE_URIS}
	"
	RESTRICT="primaryuri"
	KEYWORDS="~amd64"
	S="${WORKDIR}/${PN}-${MY_PV}"
fi

DESCRIPTION="A font compiler written in Rust"
HOMEPAGE="https://github.com/googlefonts/fontc"

LICENSE="Apache-2.0"
# Dependent crate licenses
LICENSE+=" BSD CDLA-Permissive-2.0 ISC MIT Unicode-3.0 ZLIB"
SLOT="0"

src_unpack() {
	if [[ -z ${PV%%*9999} ]]; then
		default
		git-r3_src_unpack
		cargo_live_src_unpack
	else
		cargo_src_unpack
	fi
}

src_install() {
	cargo_src_install --path fontc
	cargo_src_install --path fontc_crater
	cargo_src_install --path otl-normalizer
	einstalldocs
	newdoc fontc_crater/README.md fontc_crater.md
	newdoc otl-normalizer/README.md otl-normalizer.md
}
